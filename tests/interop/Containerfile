FROM dhi.io/rust:1-alpine3.23-dev AS runner
WORKDIR /app
ARG HTTP_PROXY HTTPS_PROXY http_proxy https_proxy ALL_PROXY all_proxy
ENV http_proxy=${HTTP_PROXY} https_proxy=${HTTPS_PROXY} HTTP_PROXY=${HTTP_PROXY} HTTPS_PROXY=${HTTPS_PROXY} ALL_PROXY=${ALL_PROXY}
COPY --from=run Cargo.toml Cargo.lock ./
RUN mkdir -p src && echo "fn main(){}" > src/main.rs
COPY --from=specodec-rust . /specodec-rust/
RUN --mount=type=cache,id=interop-rust-reg,target=/usr/local/cargo/registry \
    --mount=type=cache,id=interop-rust-tgt,target=/app/target \
    cargo build --release 2>&1 || true
COPY --from=run src/ src/
COPY --from=vectors . /app/vectors/
COPY --from=output_ts . /app/output_ts/
RUN mkdir -p /app/output_rust/scalars
ENV VEC_DIR=/app/vectors OUT_DIR=/app/output_rust
RUN --mount=type=cache,id=interop-rust-reg,target=/usr/local/cargo/registry \
    --mount=type=cache,id=interop-rust-tgt,target=/app/target \
    touch src/main.rs && cargo build --release && cp target/release/run_rust /app/run_rust_bin
RUN /app/run_rust_bin